# ===========================================
# BUILDD ENVIRONMENT VARIABLES
# ===========================================
# Copy to .env.local and fill in values
#
# VERCEL DASHBOARD - Add these environment variables:
#   - DATABASE_URL
#   - AUTH_SECRET
#   - GOOGLE_CLIENT_ID
#   - GOOGLE_CLIENT_SECRET
#   - CRON_SECRET (required for task schedules)
#   - ALLOWED_EMAILS (optional)
#   - PUSHER_* (optional, for realtime updates)
#   - NEXT_PUBLIC_PUSHER_* (optional, for realtime updates)
#
# ===========================================

# ------------------------------------------
# Database (Required)
# ------------------------------------------
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ------------------------------------------
# NextAuth (Required for web)
# ------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Your production URL (Vercel will set this automatically)
AUTH_URL=http://localhost:3000

# ------------------------------------------
# Google OAuth (Required for web)
# ------------------------------------------
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google (dev)
#   - https://your-app.vercel.app/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email whitelist (comma-separated, leave empty to allow all)
ALLOWED_EMAILS=

# ------------------------------------------
# Pusher Channels (Optional - for realtime dashboard)
# ------------------------------------------
# Create at: https://dashboard.pusher.com
# Without Pusher, dashboard works but doesn't update in realtime
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=us2

# ------------------------------------------
# Cron Jobs (Required for task schedules)
# ------------------------------------------
# Secret for authenticating the /api/cron/schedules endpoint
# This endpoint must be called every minute to trigger scheduled tasks
# Generate with: openssl rand -base64 32
# See docs/features/schedules.md for setup instructions
CRON_SECRET=

# ------------------------------------------
# Claude API (Optional - for API-based agents)
# ------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------
# Storage - Cloudflare R2 (Agent only)
# ------------------------------------------
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=buildd-artifacts
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=

# ------------------------------------------
# Agent Settings
# ------------------------------------------
DEFAULT_BRANCH_PREFIX=buildd/
WORKTREE_BASE_PATH=/tmp/buildd-worktrees
MAX_TURNS=100
MAX_COST_PER_WORKER=10.0

# ------------------------------------------
# Pushover notifications (owner ops alerts)
# ------------------------------------------
PUSHOVER_USER=
PUSHOVER_TOKEN_TASK=
PUSHOVER_TOKEN_ALERT=
# reportOps() in @buildd/core pushes swallowed warnings/errors to the "alerts"
# app. Off unless OPS_ALERTS_ENABLED is truthy. Warnings -> priority -2 (badge
# only), errors -> 0. OPS_THROTTLE_MS dedups same source+message (default 1h).
OPS_ALERTS_ENABLED=
OPS_THROTTLE_MS=
