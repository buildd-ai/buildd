#!/usr/bin/env bash
# Spec hygiene gate. Fast (pure file I/O, sub-second) so it runs on every commit.
# Blocks the commit if any spec lacks lifecycle frontmatter, cites a dead
# code-surface path, or if docs/specs/INDEX.md is stale.
#
# Registered via `git config core.hooksPath .githooks` (done automatically by the
# package.json `prepare` script on `bun install`). Bypass in a pinch with
# `git commit --no-verify`.
set -euo pipefail

if ! command -v bun >/dev/null 2>&1; then
  echo "pre-commit: bun not found, skipping spec lint" >&2
  exit 0
fi

# Never block a commit in a checkout that doesn't ship this linter (e.g. a
# different repo the runner cloned, or a partial checkout). No script → no gate.
if [ ! -f scripts/check-specs.ts ]; then
  exit 0
fi

if ! bun run scripts/check-specs.ts --check; then
  echo "" >&2
  echo "✖ spec lint failed. Fix the errors above, or run 'bun run specs:check'" >&2
  echo "  to regenerate docs/specs/INDEX.md, then re-stage and commit." >&2
  exit 1
fi

# Migration journal ordering gate. Also fast (JSON parse only, no DB) — same
# sub-second budget as the spec check above. Drizzle's migrator applies
# journal entries by `when` high-water-mark, not idx order: a new migration
# authored with a `when` at or below an already-applied later entry's `when`
# is silently SKIPPED forever in prod (exit 0, looks green, DDL never runs).
# See packages/core/__tests__/migration-journal-ordering.test.ts for the
# incident history (0067, 0021/0022).
if [ -f packages/core/__tests__/migration-journal-ordering.test.ts ]; then
  if ! bun run migrations:lint >/dev/null 2>&1; then
    echo "" >&2
    echo "✖ migration journal lint failed: the newest migration's \"when\" in" >&2
    echo "  packages/core/drizzle/meta/_journal.json is not greater than every" >&2
    echo "  prior entry — Drizzle would silently skip it. Run 'bun run migrations:lint'" >&2
    echo "  for details, then bump \"when\" and re-stage." >&2
    exit 1
  fi
fi
